set font "Lilex Nerd Font 11"

set recolor true
set recolor-keephue true
set pages-per-row 2
set first-page-column 1

# Reading colors
set recolor-lightcolor "#262626"
set recolor-darkcolor "#e8e6e3"

# Command line
set inputbar-bg "#202020"
set inputbar-fg "#00ff00"

# Status bar
set statusbar-bg "#202020"
set statusbar-fg "#00ff00"

# Completion
set completion-bg "#202020"
set completion-fg "#e8e6e3"

set completion-highlight-bg "#00ff00"
set completion-highlight-fg "#000000"

set completion-group-bg "#202020"
set completion-group-fg "#00ff00"

# Notifications
set notification-bg "#202020"
set notification-fg "#e8e6e3"

# Highlights
set highlight-color "#ffd54f"
set highlight-active-color "#ff9800"

set adjust-open width
set selection-clipboard clipboard
set scroll-step 100


