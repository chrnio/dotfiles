input type:keyboard {
    xkb_layout  us
    xkb_variant ""
    xkb_model   ""
    xkb_options ""
    repeat_delay 300
    repeat_rate  30
}

input type:touchpad {
    natural_scroll disabled
    tap            enabled
    dwt            enabled
}

# 3-finger horizontal swipe -> change workspace
bindgesture swipe:3:right workspace prev
bindgesture swipe:3:left  workspace next

input "epic-mouse-v1" {
    accel_profile flat
    pointer_accel -0.5
}

# cursor size
seat * hide_cursor 3000
seat * xcursor_theme default 24
