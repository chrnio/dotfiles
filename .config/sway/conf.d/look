font pango:JetBrainsMono NF Medium 10

gaps inner 0
gaps outer 0

default_border          pixel 2
default_floating_border pixel 2
smart_borders           on
smart_gaps              on

# class                 border    bg        text      indicator child_border
client.focused          $lavender $surface0 $text     $lavender $lavender
client.unfocused        $surface0 $base     $overlay0 $surface0 $surface0
client.focused_inactive $surface0 $base     $subtext1 $surface0 $surface0
client.urgent           $red      $base     $text     $red      $red

for_window [class=".*"]  opacity 1.0
for_window [app_id=".*"] opacity 1.0

# install autotiling-rs and add `exec autotiling` to autostart for smart splits
